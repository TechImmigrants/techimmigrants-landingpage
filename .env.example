VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# YouTube Data API v3 key — used ONLY by the GitHub Action
# (scripts/fetch-upcoming-lives.mjs), never bundled into client code.
# Add this as a GitHub repository secret, not as a Vite env var.
YOUTUBE_API_KEY=your-youtube-api-key-here
